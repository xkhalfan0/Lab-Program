# =============================================================================
# SECTION 4 — MAIN BUSINESS FLOW (sample lifecycle)
# =============================================================================

FLOW: SAMPLE_LIFECYCLE
──────────────────────────────────────────────────────────────────────────────

  [CONTRACTOR brings sample]
           │
           ▼
  ┌─────────────────────┐
  │ 1. RECEPTION        │  /reception
  │ Role: reception     │
  │ Actions:            │
  │  • Register sample  │
  │  • Select tests     │
  │  • Set qty, dates   │
  │  • CONC_CUBE: size  │
  │    + min 3 cubes    │
  │  • Create LabOrder  │
  └─────────┬───────────┘
            │ status: received → pending
            ▼
  ┌─────────────────────┐
  │ 2. DISTRIBUTION     │  /distribution
  │ Role: lab_manager   │
  │ Actions:            │
  │  • Assign technician│
  │  • Creates          │
  │    Distribution per │
  │    test in order    │
  │  • CONC_CUBE: auto  │
  │    cube groups      │
  └─────────┬───────────┘
            │ status: pending → distributed
            ▼
  ┌─────────────────────┐
  │ 3. TECHNICIAN       │  /technician
  │ Role: technician    │
  │ Actions:            │
  │  • Open assignment  │
  │  • Enter results    │
  │  • Submit test      │
  └─────────┬───────────┘
            │
            ├─ Single test ──► /test/:distId  OR  /concrete-test/:distId (CONC_CUBE)
            ├─ Batch order ──► /batch/:sampleId/:orderId
            │
            │ status: distributed → in_progress → completed
            ▼
  ┌─────────────────────┐
  │ 4. MANAGER REVIEW   │  /manager-review
  │ Role: sample_manager│
  │ Actions:            │
  │  • Review order     │
  │  • Approve / reject │
  │  • Open report      │
  └─────────┬───────────┘
            │ status: completed → reviewed
            ▼
  ┌─────────────────────┐
  │ 5. QC REVIEW        │  /qc-review
  │ Role: qc_inspector  │
  │ Actions:            │
  │  • Final QC check   │
  │  • Sign off         │
  └─────────┬───────────┘
            │ status: reviewed → qc_passed / qc_failed
            ▼
  ┌─────────────────────┐
  │ 6. CLEARANCE        │  /clearance
  │ Role: accountant    │
  │ Actions:            │
  │  • Payment order    │
  │  • Issue certificate│
  │  • Print PDF        │
  └─────────┬───────────┘
            │ status: cleared
            ▼
  [Certificate to contractor]
            │
            ▼
  ┌─────────────────────┐
  │ SECTOR PORTAL       │  /sector/*
  │ Role: sector user   │
  │ Actions:            │
  │  • View samples     │
  │  • Download certs   │
  │  • Notifications    │
  └─────────────────────┘


# =============================================================================
# SECTION 5 — TECHNICIAN ROUTING (distribution → test form)
# =============================================================================

TECHNICIAN_START_TEST
  Technician clicks "Start Test" on assignment card
           │
           ├── testType === CONC_CUBE
           │       └── /concrete-test/:distributionId  → ConcreteTest.tsx
           │           (BS 1881: f'c, test date, load, cube ID, mass)
           │
           ├── batch (multiple tests same order)
           │       └── /batch/:sampleId/:orderId  → BatchOverview.tsx
           │           └── each test → /test/:distributionId
           │
           └── all other tests
                   └── /test/:distributionId  → TestRouter.tsx
                       └── resolves by testType code → form component


TEST_CODE_TO_FORM (TestRouter CODE_TO_COMPONENT — selected)
  CONC_CUBE          → ConcreteCubes (legacy) | ConcreteTest (new flow via Technician)
  CONC_CORE          → ConcreteCore
  CONC_BLOCK         → ConcreteBlocks
  CONC_FOAM          → ConcreteFoam
  CONC_BEAM          → ConcreteBeam
  SOIL_PROCTOR       → SoilProctor
  SOIL_CBR           → SoilCBR
  SOIL_ATTERBERG     → SoilAtterberg
  STEEL_REBAR        → SteelRebar
  ASPH_MARSHALL      → AsphaltMarshall
  ASPH_HOTBIN        → AsphaltHotBin
  AGG_SIEVE          → SieveAggBlend
  AGG_LA             → AggLAAbrasion
  ... (32+ official test codes in TestRouter.tsx)


# =============================================================================
# SECTION 6 — REPORT ROUTING (after test complete)
# =============================================================================

REPORT_ROUTING
  Manager / Technician clicks "View Report"
           │
           ├── CONC_CUBE
           │       └── /concrete-report/:distributionId  → ConcreteReport.tsx
           │
           ├── specialized test (formData in specializedTestResults)
           │       └── /test-report/:distributionId  → SpecializedTestReport.tsx
           │
           ├── batch order
           │       └── /batch-report/:sampleId/:orderId  → BatchReport.tsx
           │
           └── full order summary
                   └── /order-report/:orderId  → OrderReport.tsx


# =============================================================================
# SECTION 7 — CONC_CUBE SPECIAL FLOW (current implementation)
# =============================================================================

CONC_CUBE_FLOW
  RECEPTION
    • Select CONC_CUBE test
    • Quantity inline (min 3 cubes)
    • Nominal cube size: 100mm / 150mm
    • Casting date on sample
    • Plan stored: testSubType = CONC_CUBE_PLAN:{"v":2,"cubeSizeMm":150,"cubeCount":N}
           │
           ▼
  DISTRIBUTION
    • ensureConcreteGroupsFromReceptionPlan()
    • Creates 1 concrete_test_group (testAge=0)
    • Creates N placeholder concrete_cubes
           │
           ▼
  TECHNICIAN  /concrete-test/:distributionId
    • Locked: casting date, cube size, cube count
    • Enters: f'c (design strength), test date, per-cube load/mass/ID/fracture
    • Age auto-calculated: test date − casting date
    • BS 1881 factor applied for pass/fail
    • Submit group → manager review
           │
           ▼
  REPORT  /concrete-report/:distributionId
    • BS 1881 formatted table
    • Exact test age (days) in results table
    • Required strength from actual age factor


# =============================================================================
# SECTION 8 — API TREE (tRPC appRouter namespaces)
# =============================================================================

API_TRPC
  auth                 login, logout, me, changePassword
  users                CRUD, permissions
  samples              create, list, detail, history, status
  distributions        create, assign, get, list by tech/sample/batch
  orders               reception create (multi-test orders)
  testResults          submit, get, approve
  specializedTests     save formData, submit, get
  concrete             groups, cubes, saveCube, submitGroup
  reviews              manager + QC decisions
  clearance            requests, payment, certificate
  certificates         issue, PDF
  testTypes            catalog CRUD
  contractors          CRUD
  contracts            CRUD
  analytics            stats, charts
  reports              monthly, export
  notifications        list, mark read
  sectors              sector admin
  testDependencies     prerequisite rules
  deletion             soft-delete requests
  dashboard            KPIs
  audit                audit log
  sector               sector portal (separate auth)


# =============================================================================
# SECTION 9 — DATA ENTITY RELATIONSHIPS (simplified)
# =============================================================================

ENTITIES
  Contract
    └── Sample (sampleCode: LAB-2026-XXXX)
          ├── LabOrder (orderCode: ORD-2026-XXXX)
          │     └── LabOrderItem[] (one per selected test)
          │
          ├── Distribution[] (one per test after distribute)
          │     ├── specializedTestResult (most tests)
          │     ├── concreteTestGroup + concreteCubes (CONC_CUBE)
          │     └── testResult (legacy bridge)
          │
          ├── Reviews[] (manager, QC)
          ├── ClearanceRequest
          ├── Certificate
          └── SampleHistory[]


