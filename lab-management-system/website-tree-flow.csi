# =============================================================================
# SECTION 1 — PROJECT DIRECTORY TREE (high level)
# =============================================================================

Lab-Program/
└── lab-management-system/
    ├── client/                          # Frontend (React SPA)
    │   ├── src/
    │   │   ├── App.tsx                  # All routes + role guards
    │   │   ├── _core/                   # Auth hooks, session
    │   │   ├── components/
    │   │   │   ├── DashboardLayout.tsx  # Sidebar nav (role/permission based)
    │   │   │   ├── PrintHeader.tsx      # Standard print header
    │   │   │   ├── reports/             # FlexibleResultsTable, etc.
    │   │   │   └── ui/                  # shadcn components
    │   │   ├── contexts/                # Language, Theme
    │   │   ├── lib/                     # PDF, batch helpers, specs
    │   │   └── pages/
    │   │       ├── Login.tsx
    │   │       ├── Reception.tsx        # Step 1: create sample + order
    │   │       ├── Distribution.tsx     # Step 2: assign technician
    │   │       ├── Technician.tsx       # Step 3: run tests
    │   │       ├── ManagerReview.tsx    # Step 4: supervisor review
    │   │       ├── QCReview.tsx         # Step 5: QC approval
    │   │       ├── ClearancePage.tsx    # Step 6: payment + certificate
    │   │       ├── ConcreteTest.tsx     # CONC_CUBE tech form (BS 1881)
    │   │       ├── ConcreteReport.tsx   # CONC_CUBE print report
    │   │       ├── BatchOverview.tsx    # Multi-test batch hub
    │   │       ├── BatchReport.tsx      # Batch combined report
    │   │       ├── OrderReport.tsx      # Unified order report
    │   │       ├── SampleDetail.tsx
    │   │       ├── AdminDashboard.tsx
    │   │       ├── Analytics.tsx
    │   │       ├── tests/
    │   │       │   ├── TestRouter.tsx   # Routes dist → correct form
    │   │       │   ├── SpecializedTestReport.tsx
    │   │       │   ├── ConcreteCubes.tsx, ConcreteCore.tsx, ...
    │   │       │   └── [30+ test form pages]
    │   │       └── sector/              # External sector portal
    │   │           ├── SectorLogin.tsx
    │   │           ├── SectorInbox.tsx
    │   │           ├── SectorSamples.tsx
    │   │           ├── SectorResults.tsx
    │   │           └── SectorClearances.tsx
    │   └── index.html
    │
    ├── server/                          # Backend (Express + tRPC)
    │   ├── routers.ts                   # Main appRouter (all API namespaces)
