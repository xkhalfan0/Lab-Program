# =============================================================================
# SECTION 2 — ROUTE TREE (URL → Page → Access)
# =============================================================================

ROUTES
│
├── PUBLIC
│   ├── /login                           → Login
│   └── /sector/login                    → SectorLogin
│
├── AUTH REDIRECT
│   └── /                                  → SmartHomeRedirect (role-based landing)
│
├── LAB STAFF (authenticated; some role-restricted)
│   │
│   ├── DASHBOARDS
│   │   ├── /admin-dashboard               → AdminDashboard
│   │   ├── /supervisor-dashboard          → SupervisorDashboard
│   │   └── /manager-dashboard             → ManagerDashboard
│   │
│   ├── WORKFLOW (main pipeline)
│   │   ├── /reception                     → Reception          [admin, reception, lab_manager]
│   │   ├── /distribution                  → Distribution       [admin, lab_manager]
│   │   ├── /technician                    → Technician         [admin, technician, lab_manager]
│   │   ├── /manager-review                → ManagerReview      [admin, sample_manager, lab_manager]
│   │   ├── /qc-review                     → QCReview           [admin, qc_inspector, lab_manager]
│   │   └── /clearance                     → ClearancePage      [admin, lab_manager, sample_manager, accountant]
│   │
│   ├── SAMPLES & ORDERS
│   │   ├── /sample/:id                    → SampleDetail
│   │   ├── /samples/:id                   → SampleDetail (alias)
│   │   ├── /order/:id                     → OrderReport
│   │   └── /order-report/:orderId         → OrderReport
│   │
│   ├── TECHNICIAN TEST FORMS
│   │   ├── /test/:distributionId          → TestRouter (generic → form by test code)
│   │   ├── /concrete-test/:distributionId → ConcreteTest (CONC_CUBE BS 1881 flow)
│   │   └── /batch/:sampleId/:orderId      → BatchOverview (multi-test batch)
│   │
│   ├── REPORTS (often opened in new tab)
│   │   ├── /test-report/:distributionId   → SpecializedTestReport (most tests)
│   │   ├── /concrete-report/:distributionId → ConcreteReport (CONC_CUBE only)
│   │   ├── /batch-report/:sampleId/:orderId → BatchReport
│   │   ├── /batch-report/:batchId         → BatchBlockReport
│   │   ├── /print-receipt/:id             → PrintReceipt
│   │   └── /print-certificate/:id         → PrintCertificate
│   │
│   ├── ADMIN & SETTINGS
│   │   ├── /users                         → UserManagement       [admin]
│   │   ├── /tests-management              → TestTypesManagement  [admin]
│   │   ├── /admin/deletion-requests       → AdminDeletionRequests
│   │   └── /admin/deletion-log            → DeletionLog
│   │
│   └── UTILITIES
│       ├── /notifications                 → Notifications
│       ├── /analytics                     → Analytics
│       ├── /monthly-report                → MonthlyReport
│       ├── /clearance-archive             → ClearanceArchive
│       └── /change-password               → ChangePassword
│
└── SECTOR PORTAL (separate token: sector_token)
    ├── /sector                            → redirect → /sector/inbox or /sector/login
    ├── /sector/inbox                      → SectorInbox
    ├── /sector/dashboard                  → SectorDashboard
    ├── /sector/samples                    → SectorSamples
    ├── /sector/results                    → SectorResults
    ├── /sector/clearances                 → SectorClearances
    └── /sector/notifications              → SectorNotifications


