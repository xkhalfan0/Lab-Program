{
  "name": "lab-management-system",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "postinstall": "node node_modules/puppeteer/install.mjs",
    "start": "node dist/index.js",
    "start:migrate": "pnpm run db:full-migration && node dist/index.js",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "verify-migration": "tsx server/scripts/verify-migration.ts",
    "test:migration": "pnpm run verify-migration",
    "test:status-flow": "tsx server/scripts/test-status-flow.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:add-fks": "tsx server/scripts/add-foreign-keys.ts",
    "db:add-soft-delete": "tsx server/scripts/add-soft-delete-columns.ts",
    "db:check-integrity": "tsx server/scripts/check-integrity.ts",
    "db:clean-orphans": "tsx server/scripts/clean-orphan-data.ts",
    "db:full-migration": "tsx server/scripts/run-full-migration.ts",
    "db:retest-columns": "tsx server/scripts/add-retest-columns.ts",
    "db:reference-no": "tsx server/scripts/add-reference-no-column.ts",
    "db:contractor-form-type": "tsx server/scripts/add-contractor-form-attachment-type.ts",
    "db:concrete-cube-test-conditions": "tsx server/scripts/add-concrete-cube-test-conditions-columns.ts",
    "db:migration:phase1": "npm run db:check-integrity && npm run db:add-fks && npm run db:add-soft-delete",
    "db:rollback-fks": "tsx server/scripts/rollback-fks.ts",
    "db:reset:tests": "tsx server/scripts/reset-test-data.ts",
    "db:seed:contractors": "tsx server/scripts/seed-contractors-projects.ts",
    "db:seed:users": "tsx server/scripts/seed-role-users.ts",
    "db:seed:sectors": "tsx server/scripts/seed-sector-accounts.ts",
    "db:check-deletion-table": "tsx server/scripts/check-deletion-table.ts",
    "db:seed:test-types": "tsx server/scripts/seed-test-types.ts",
    "seed:demo": "tsx server/scripts/seedDemo.ts",
    "db:import:catalog": "tsx server/scripts/import-catalog.ts",
    "db:import:contracts-sql": "node server/scripts/run-sql-file.mjs",
    "db:cleanup:test-duplicates": "tsx server/scripts/cleanup-duplicate-tests.ts",
    "backup": "bash backup.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.693.0",
    "@aws-sdk/s3-request-presigner": "^3.693.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
